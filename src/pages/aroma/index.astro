---
import Layout from '../../layouts/Layout.astro';
import AromaChat from '../../components/aroma/AromaChat.astro';
import AromaGuide from '../../components/aroma/AromaGuide.astro';
import oilsData from '../../data/aroma_oils.json';
---

<Layout
	title="精油を探す | Natural Quest"
	description="症状・気分・目的を自由に入力すると、60種の精油データをもとにAIがあなたに合った香りを提案します。"
	narrow
>
	<div class="space-y-6">
		<header class="text-center">
			<h1 class="font-serif text-3xl font-semibold tracking-tight sm:text-4xl">アロマAIチャット</h1>
			<p class="mt-4 font-sans text-sm leading-relaxed text-nq-muted sm:text-base">
				アロマ（精油）選びは種類がたくさんあって、どれがいいのか迷ってしまいますね。<br />
				このAIチャットで、今のあなたの気分や目的にあった精油を探しましょう。<br />
				きっとヒントが見つかりますよ。
			</p>
		</header>

		<AromaChat oilsData={oilsData} />

		<AromaGuide />
	</div>
</Layout>

