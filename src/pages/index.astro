---
import Layout from '../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { isJournalPublic } from '../lib/journalPublic';

/** 同日付の記事が複数あるとき、トップの並び（新着・HERO・カテゴリの最新にも影響） */
const SAME_DAY_ORDER: string[] = [
	'2026-04-08-sickhouse',
	'2026-04-08-natural-paint-guide',
	'2026-04-08-shikkui-materials-guide',
];

/** TOP 2ndエリア：手動ピックアップ（ジャーナル記事スラッグを最大4件） */
const homePickSlugs: string[] = [
	'2026-04-08-sickhouse',
	'2026-04-08-natural-paint-guide',
	'2026-04-08-shikkui-materials-guide',
	'2026-04-04-shikkui',
];

/** サイドバー：人気の記事（3件・手動指定） */
const popularSlugs: string[] = [
	'garlic-ajoene-oil',
	'herb-aroma-azuki',
	'herb-aroma-v1-drink',
];

/** セレクション：編集部おすすめ（6件・手動指定） */
const selectionSlugs: string[] = [
	'2026-04-04-shikkui',
	'herb-aroma-azuki',
	'garlic-ajoene-oil',
	'apple-syrup-preserve',
	'2017-01-22-heirloom-veg-photo',
	'2018-09-18-climate-urgent',
];

const allPostsRaw = await getCollection('journal');
const posts = allPostsRaw.filter(isJournalPublic);
const allPosts = posts;
const sorted = posts.sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	if (dateB !== dateA) return dateB - dateA;
	const ia = SAME_DAY_ORDER.indexOf(a.slug);
	const ib = SAME_DAY_ORDER.indexOf(b.slug);
	if (ia !== -1 || ib !== -1) {
		if (ia === -1) return 1;
		if (ib === -1) return -1;
		return ia - ib;
	}
	return a.slug.localeCompare(b.slug, 'ja');
});

type JournalPost = CollectionEntry<'journal'>;

function categoryLabel(post: JournalPost): string {
	return post.data.categories?.[0] ?? '記事';
}

function formatDate(post: JournalPost): string {
	if (!post.data.pubDate) return '';
	return post.data.pubDate.toLocaleDateString('ja-JP', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	});
}

function normalizeSlugKey(s: string): string {
	const withoutExt = /\.mdx?$/i.test(s) ? s.replace(/\.mdx?$/i, '') : s;
	return withoutExt.normalize('NFC');
}

function resolvePost(slug: string): JournalPost | undefined {
	const key = normalizeSlugKey(slug);
	return sorted.find((p) => normalizeSlugKey(p.slug) === key);
}

function latestInCategory(cat: string, n: number): JournalPost[] {
	return sorted.filter((p) => p.data.categories?.includes(cat)).slice(0, n);
}

const FEATURED_SLUG = '2026-04-04-shikkui'; // ← 固定したい記事スラッグ

const featuredFixed = allPosts.find((p) => p.slug === FEATURED_SLUG);
const featured = featuredFixed ?? sorted[0] ?? undefined; // 非公開のみのときは空
const homePicks = homePickSlugs
	.map(resolvePost)
	.filter((p): p is JournalPost => p != null && isJournalPublic(p));

const popularPosts = popularSlugs
	.map(resolvePost)
	.filter((p): p is JournalPost => p != null && isJournalPublic(p));

const selectionPosts = selectionSlugs
	.map(resolvePost)
	.filter((p): p is JournalPost => p != null && isJournalPublic(p));

const CATEGORY_ORDER = ['住む', '食', '健康', 'NOTE'] as const;

/** 後日 `true` にすると TOPICS（UI上の見出しは「PICK UP」）ブロックを表示 */
const SHOW_TOPICS = false;

/** カテゴリ名ラベル（全セクション共通） */
const catLabelClass =
	'inline-flex w-fit max-w-full shrink-0 items-center rounded border border-nq-accent-warm/45 bg-nq-accent-warm/12 px-2 py-1 font-sans text-[11px] font-bold leading-tight tracking-[0.08em] text-nq-accent-warm sm:text-xs';
---

<Layout title="Natural Quest" description="自分のナチュラルを見つける — Natural Quest">
	<div class="mx-auto max-w-[1200px] text-nq-ink sm:px-1 lg:px-2">
		<!-- 1. メイン HERO（2カラム：左メインを広く・高めに） -->
		<section class="mb-5 grid grid-cols-1 gap-4 border-b border-nq-border pb-5 lg:mb-6 lg:grid-cols-12 lg:gap-6 lg:pb-6">
			<div class="lg:col-span-9">
				{
					featured ? (
						<article class="flex flex-col gap-2.5">
							<a
								href={`/journal/${featured.slug}`}
								class="relative left-1/2 block aspect-[4/3] w-screen -translate-x-1/2 overflow-hidden bg-nq-border/25 ring-1 ring-nq-border/60 min-h-[200px] sm:aspect-[5/3] sm:min-h-[240px] lg:aspect-[16/9] lg:left-auto lg:min-h-[280px] lg:w-full lg:translate-x-0 xl:min-h-[340px]"
							>
								{featured.data.heroImage ? (
									<img
										src={featured.data.heroImage}
										alt=""
										class="h-full w-full object-cover object-center transition-opacity hover:opacity-95"
										loading="eager"
										decoding="async"
									/>
								) : (
									<div
										class="flex h-full min-h-[140px] items-center justify-center bg-gradient-to-br from-nq-border/90 to-nq-accent/15"
										aria-hidden="true"
									>
										<span class="font-sans text-[10px] tracking-widest text-nq-muted">NO IMAGE</span>
									</div>
								)}
							</a>
							<h1 class="font-serif text-[1.35rem] font-semibold leading-snug tracking-tight text-nq-ink sm:text-2xl">
								<a href={`/journal/${featured.slug}`} class="transition-colors hover:text-nq-accent-warm">
									{featured.data.title ?? '無題の記事'}
								</a>
							</h1>
							<p class:list={[catLabelClass]}>{categoryLabel(featured)}</p>
							{featured.data.description ? (
								<p class="line-clamp-3 font-sans text-sm leading-relaxed text-nq-ink/80">
									{featured.data.description}
								</p>
							) : null}
							<a
								href={`/journal/${featured.slug}`}
								class="inline-flex w-fit items-center gap-1 border-b border-nq-ink/70 pb-0.5 font-sans text-[11px] font-semibold tracking-[0.12em] text-nq-ink transition-colors hover:border-nq-accent-warm hover:text-nq-accent-warm"
							>
								続きを読む
							</a>
						</article>
					) : (
						<p class="font-sans text-sm text-nq-muted">記事がまだありません。</p>
					)
				}
			</div>

			<aside class="lg:col-span-3" aria-label="人気の記事">
				<div class="mb-2 flex items-center gap-2 pb-1.5">
					<h2 class="shrink-0 font-sans text-xs font-bold tracking-[0.18em] text-nq-ink">人気の記事</h2>
					<span class="h-px flex-1 bg-nq-border" aria-hidden="true" />
				</div>
				<ul class="flex flex-col">
					{popularPosts.map((post, i) => (
						<li
							class:list={[
								'flex gap-3 border-b border-nq-border/45 py-3.5 first:pt-1',
								i === popularPosts.length - 1 && 'border-b-0 pb-0',
							]}
						>
							<a
								href={`/journal/${post.slug}`}
								class="relative aspect-square size-[4.5rem] shrink-0 overflow-hidden bg-nq-border/40 ring-1 ring-nq-border/50 sm:size-[5rem]"
							>
								{post.data.heroImage ? (
									<img
										src={post.data.heroImage}
										alt=""
										class="absolute inset-0 h-full w-full object-cover object-center"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div
										class="absolute inset-0 bg-gradient-to-br from-nq-border/70 via-nq-border/45 to-nq-border/25"
										aria-hidden="true"
									/>
								)}
							</a>
							<div class="min-w-0 flex-1 pt-0">
								<p class:list={[catLabelClass, 'mb-1']}>{categoryLabel(post)}</p>
								<h3 class="line-clamp-3 font-serif text-sm font-semibold leading-snug text-nq-ink">
									<a href={`/journal/${post.slug}`} class="transition-colors hover:text-nq-accent">
										{post.data.title ?? '無題'}
									</a>
								</h3>
							</div>
						</li>
					))}
				</ul>
			</aside>
		</section>

		<!-- 2. TOPICS / PICK UP（SHOW_TOPICS が true のときのみ表示） -->
		{
			SHOW_TOPICS ? (
				<section class="mb-5 lg:mb-6">
					<div class="relative mb-3 flex items-center gap-3">
						<div class="h-px flex-1 bg-nq-border" aria-hidden="true" />
						<h2 class="shrink-0 font-sans text-xs font-bold tracking-[0.22em] text-nq-muted">TOPICS</h2>
						<div class="h-px flex-1 bg-nq-border" aria-hidden="true" />
					</div>
					{
						homePicks.length ? (
							<ul class="grid grid-cols-1 gap-0 divide-y divide-nq-border/80 md:grid-cols-2 md:gap-x-3 md:gap-y-5 md:divide-y-0 lg:grid-cols-4 lg:gap-x-3 lg:gap-y-0">
								{homePicks.map((post) => (
									<li class="min-w-0 py-3 first:pt-0 md:py-0">
										<a href={`/journal/${post.slug}`} class="group flex h-full min-w-0 gap-2.5 sm:gap-3">
											<div class="relative aspect-square size-[4.5rem] shrink-0 overflow-hidden bg-nq-border/40 ring-1 ring-nq-border/50 sm:size-[5rem]">
												{post.data.heroImage ? (
													<img
														src={post.data.heroImage}
														alt=""
														class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-[1.02]"
														loading="lazy"
														decoding="async"
													/>
												) : (
													<div
														class="absolute inset-0 bg-gradient-to-br from-nq-border/70 via-nq-border/45 to-nq-border/25"
														aria-hidden="true"
													/>
												)}
											</div>
											<div class="flex min-w-0 flex-1 flex-col gap-1">
												<h3 class="line-clamp-3 font-serif text-sm font-semibold leading-snug text-nq-ink sm:text-[0.95rem]">
													<span class="transition-colors group-hover:text-nq-accent-warm">{post.data.title ?? '無題'}</span>
												</h3>
												{post.data.description ? (
													<p class="line-clamp-2 font-sans text-xs leading-relaxed text-nq-ink/78 sm:text-[13px]">
														{post.data.description}
													</p>
												) : null}
												<p class:list={[catLabelClass, 'mt-auto w-fit']}>{categoryLabel(post)}</p>
												<p class="font-sans text-[11px] tabular-nums text-nq-muted">{formatDate(post)}</p>
											</div>
										</a>
									</li>
								))}
							</ul>
						) : (
							<p class="font-sans text-sm text-nq-muted">ピックアップ記事が設定されていません。</p>
						)
					}
				</section>
			) : null
		}

		<!-- 3. 編集部セレクション（6記事・2列） -->
		<section class="pt-5">
			<div class="mb-3 flex items-center justify-between">
				<h2 class="font-serif text-base font-semibold tracking-tight text-nq-ink sm:text-lg">編集部セレクション</h2>
			</div>
			{
				selectionPosts.length ? (
					<ul class="grid grid-cols-1 gap-2 sm:grid-cols-3 sm:gap-x-2.5">
						{selectionPosts.map((post) => (
							<li class="min-w-0">
								<a
									href={`/journal/${post.slug}`}
									class="group flex h-full min-w-0 flex-col overflow-hidden rounded-sm border border-nq-border/80 bg-white/40 transition-colors hover:border-nq-accent/50"
								>
									<div class="relative aspect-video w-full shrink-0 overflow-hidden bg-nq-border/30">
										{post.data.heroImage ? (
											<img
												src={post.data.heroImage}
												alt=""
												class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-[1.02]"
												loading="lazy"
												decoding="async"
											/>
										) : (
											<div
												class="absolute inset-0 bg-gradient-to-br from-nq-border/55 via-nq-border/35 to-nq-border/20"
												aria-hidden="true"
											/>
										)}
									</div>
									<div class="flex flex-1 flex-col gap-1 p-2">
										<p class:list={[catLabelClass]}>{categoryLabel(post)}</p>
										<h3 class="line-clamp-2 font-serif text-[13px] font-semibold leading-snug text-nq-ink sm:text-sm">
											{post.data.title ?? '無題'}
										</h3>
										<p class="mt-auto font-sans text-[11px] tabular-nums text-nq-muted">{formatDate(post)}</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="font-sans text-sm text-nq-muted">記事を準備中です。</p>
				)
			}
		</section>

		<!-- CATEGORY_SECTION_START -->
		{
			false && (
				<div class="flex flex-col gap-5">
					{CATEGORY_ORDER.map((cat) => {
						const catPosts = latestInCategory(cat, 3);
						return (
							<section class="border-t border-nq-border pt-4 first:border-t-0 first:pt-0">
								<div class="mb-2.5 flex flex-wrap items-end justify-between gap-2">
									<h2 class="font-serif text-base font-semibold tracking-tight text-nq-ink sm:text-lg">{cat}</h2>
									<a
										href={`/category/${encodeURIComponent(cat)}`}
										class="font-sans text-[11px] font-semibold tracking-[0.1em] text-nq-muted transition-colors hover:text-nq-accent"
									>
										一覧へ →
									</a>
								</div>
								{catPosts.length ? (
									<ul class="grid grid-cols-1 gap-2 sm:grid-cols-3 sm:gap-x-2.5">
										{catPosts.map((post) => (
											<li class="min-w-0">
												<a
													href={`/journal/${post.slug}`}
													class="group flex h-full min-w-0 flex-col overflow-hidden rounded-sm border border-nq-border/80 bg-white/40 transition-colors hover:border-nq-accent/50"
												>
													<div class="relative aspect-video w-full shrink-0 overflow-hidden bg-nq-border/30">
														{post.data.heroImage ? (
															<img
																src={post.data.heroImage}
																alt=""
																class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-300 group-hover:scale-[1.02]"
																loading="lazy"
																decoding="async"
															/>
														) : (
															<div
																class="absolute inset-0 bg-gradient-to-br from-nq-border/55 via-nq-border/35 to-nq-border/20"
																aria-hidden="true"
															/>
														)}
													</div>
													<div class="flex flex-1 flex-col gap-1 p-2">
														<p class:list={[catLabelClass]}>{categoryLabel(post)}</p>
														<h3 class="line-clamp-2 font-serif text-[13px] font-semibold leading-snug text-nq-ink sm:text-sm">
															{post.data.title ?? '無題'}
														</h3>
														<p class="mt-auto font-sans text-[11px] tabular-nums text-nq-muted">{formatDate(post)}</p>
													</div>
												</a>
											</li>
										))}
									</ul>
								) : (
									<p class="font-sans text-sm text-nq-muted">このカテゴリの記事はまだありません。</p>
								)}
							</section>
						);
					})}
				</div>
			)
		}
		<!-- CATEGORY_SECTION_END -->

		<!-- 4. アロマチャットバナー -->
		<section class="mt-6 border-t border-nq-border pt-5" aria-label="アロマAIチャット">
			<div class="hero-aroma">
				<img
					src="/images/herbaroma.jpg"
					alt=""
					class="hero-aroma-img"
					loading="lazy"
					decoding="async"
				/>
				<div class="hero-aroma-text">
					<p class="font-sans text-[11px] font-light leading-snug tracking-wide text-nq-muted sm:text-xs">
						精油選びに迷ったら
					</p>
					<p class="font-serif text-xl font-semibold tracking-tight text-nq-ink sm:text-2xl">アロマAIチャット</p>
					<p class="max-w-xl font-sans text-sm leading-relaxed text-nq-text">
						気分や症状を話しかけると、あなたに合う精油をご提案します。
					</p>
					<a
						href="/aroma/"
						class="inline-flex w-fit items-center justify-center rounded-[24px] bg-[#2d6a4f] px-6 py-3 font-sans text-xs font-bold tracking-[0.12em] text-white transition-opacity hover:opacity-92"
					>
						チャットを開く
					</a>
				</div>
			</div>
		</section>
	</div>

	<style>
		.hero-aroma {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0;
			border-radius: 12px;
			overflow: hidden;
			background: #f5f2eb;
			min-height: 220px;
		}

		.hero-aroma-img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}

		.hero-aroma-text {
			padding: 2rem;
			display: flex;
			flex-direction: column;
			justify-content: center;
			gap: 1rem;
		}

		@media (max-width: 600px) {
			.hero-aroma {
				grid-template-columns: 1fr;
			}
			.hero-aroma-img {
				height: 180px;
				object-fit: cover;
			}
		}
	</style>
</Layout>
