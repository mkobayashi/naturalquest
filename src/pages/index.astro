---
import Layout from '../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

/** TOP 2ndエリア：手動ピックアップ（ジャーナル記事スラッグを最大4件） */
const homePickSlugs: string[] = [
	'2026-04-07-漆喰を古民家の土蔵に塗ってみた',
	'酵素',
	'花粉充満',
	'謹賀新年-2021',
];

const posts = await getCollection('journal');
const sorted = posts.sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return dateB - dateA;
});

type JournalPost = CollectionEntry<'journal'>;

function categoryLabel(post: JournalPost): string {
	return post.data.categories?.[0] ?? '記事';
}

function formatDate(post: JournalPost): string {
	if (!post.data.pubDate) return '';
	return post.data.pubDate.toLocaleDateString('ja-JP', {
		year: 'numeric',
		month: 'short',
		day: 'numeric',
	});
}

function resolvePost(slug: string): JournalPost | undefined {
	return sorted.find((p) => p.slug === slug);
}

function latestInCategory(cat: string, n: number): JournalPost[] {
	return sorted.filter((p) => p.data.categories?.includes(cat)).slice(0, n);
}

const featured = sorted[0];
const newListFive = sorted.slice(1, 6);
const homePicks = homePickSlugs.map(resolvePost).filter((p): p is JournalPost => p != null);

const CATEGORY_ORDER = ['住環境', '食', '健康', 'NOTE'] as const;

/** カテゴリ名ラベル（全セクション共通） */
const catLabelClass =
	'inline-flex w-fit max-w-full shrink-0 items-center rounded border border-nq-accent-warm/45 bg-nq-accent-warm/12 px-2 py-1 font-sans text-[11px] font-bold leading-tight tracking-[0.08em] text-nq-accent-warm sm:text-xs';
---

<Layout title="Natural Quest" description="自分のナチュラルを見つける — Natural Quest">
	<div class="mx-auto max-w-[1200px] text-nq-ink">
		<!-- 1. メイン HERO（2カラム） -->
		<section class="mb-8 grid grid-cols-1 gap-6 border-b border-nq-border pb-8 lg:mb-10 lg:grid-cols-12 lg:gap-8 lg:pb-10">
			<div class="lg:col-span-8">
				{
					featured ? (
						<article class="flex flex-col gap-3">
							<a
								href={`/journal/${featured.slug}`}
								class="relative block aspect-[16/9] w-full overflow-hidden bg-nq-border/25 ring-1 ring-nq-border/60"
							>
								{featured.data.heroImage ? (
									<img
										src={featured.data.heroImage}
										alt=""
										class="h-full w-full object-cover transition-opacity hover:opacity-95"
										loading="eager"
										decoding="async"
									/>
								) : (
									<div
										class="flex h-full min-h-[140px] items-center justify-center bg-gradient-to-br from-nq-border/90 to-nq-accent/15"
										aria-hidden="true"
									>
										<span class="font-sans text-[10px] tracking-widest text-nq-muted">NO IMAGE</span>
									</div>
								)}
							</a>
							<h1 class="font-serif text-[1.35rem] font-semibold leading-snug tracking-tight text-nq-ink sm:text-2xl">
								<a href={`/journal/${featured.slug}`} class="transition-colors hover:text-nq-accent-warm">
									{featured.data.title ?? '無題の記事'}
								</a>
							</h1>
							<p class:list={[catLabelClass]}>{categoryLabel(featured)}</p>
							{featured.data.description ? (
								<p class="line-clamp-3 font-sans text-sm leading-relaxed text-nq-ink/80">
									{featured.data.description}
								</p>
							) : null}
							<a
								href={`/journal/${featured.slug}`}
								class="inline-flex w-fit items-center gap-1 border-b border-nq-ink/70 pb-0.5 font-sans text-[11px] font-semibold tracking-[0.12em] text-nq-ink transition-colors hover:border-nq-accent-warm hover:text-nq-accent-warm"
							>
								続きを読む
							</a>
						</article>
					) : (
						<p class="font-sans text-sm text-nq-muted">記事がまだありません。</p>
					)
				}
			</div>

			<aside class="lg:col-span-4" aria-label="新着記事">
				<div class="mb-3 flex items-center gap-2 border-b border-nq-border pb-2">
					<h2 class="font-sans text-xs font-bold tracking-[0.18em] text-nq-ink">新着</h2>
					<span class="h-px flex-1 bg-nq-border" aria-hidden="true" />
				</div>
				<ol class="flex flex-col gap-0">
					{newListFive.map((post, i) => (
						<li
							class:list={[
								'flex gap-3 border-b border-nq-border/50 py-3 first:pt-0',
								i === newListFive.length - 1 && 'border-b-0 pb-0',
							]}
						>
							<span
								class="w-5 shrink-0 pt-1 font-serif text-base font-semibold tabular-nums text-nq-muted"
								aria-hidden="true"
							>
								{i + 1}
							</span>
							<a
								href={`/journal/${post.slug}`}
								class="relative aspect-square h-[5.25rem] w-[5.25rem] shrink-0 overflow-hidden bg-nq-border/30 ring-1 ring-nq-border/45 sm:h-24 sm:w-24"
							>
								{post.data.heroImage ? (
									<img
										src={post.data.heroImage}
										alt=""
										class="h-full w-full object-cover"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div
										class="flex h-full w-full items-center justify-center bg-gradient-to-br from-nq-border/80 to-nq-accent/10"
										aria-hidden="true"
									>
										<span class="font-sans text-[9px] text-nq-muted">—</span>
									</div>
								)}
							</a>
							<div class="min-w-0 flex-1 pt-0.5">
								<p class:list={[catLabelClass, 'mb-1.5']}>{categoryLabel(post)}</p>
								<h3 class="line-clamp-3 font-serif text-sm font-semibold leading-snug text-nq-ink sm:text-base">
									<a href={`/journal/${post.slug}`} class="transition-colors hover:text-nq-accent">
										{post.data.title ?? '無題'}
									</a>
								</h3>
							</div>
						</li>
					))}
				</ol>
			</aside>
		</section>

		<!-- 2. PICK UP（新着と同型：左サムネ正方形／右テキスト） -->
		<section class="mb-8 lg:mb-10">
			<div class="relative mb-4 flex items-center gap-3">
				<div class="h-px flex-1 bg-nq-border" aria-hidden="true" />
				<h2 class="shrink-0 font-sans text-xs font-bold tracking-[0.22em] text-nq-muted">PICK UP</h2>
				<div class="h-px flex-1 bg-nq-border" aria-hidden="true" />
			</div>
			{
				homePicks.length ? (
					<ul class="grid grid-cols-1 gap-0 divide-y divide-nq-border/80 md:grid-cols-3 md:gap-x-4 md:gap-y-8 md:divide-y-0">
						{homePicks.map((post) => (
							<li class="py-4 first:pt-0 md:py-0">
								<a href={`/journal/${post.slug}`} class="group flex h-full gap-3 sm:gap-4 md:gap-2.5 lg:gap-3">
									<div class="relative aspect-square h-[5.25rem] w-[5.25rem] shrink-0 overflow-hidden bg-nq-border/30 ring-1 ring-nq-border/45 sm:h-24 sm:w-24">
										{post.data.heroImage ? (
											<img
												src={post.data.heroImage}
												alt=""
												class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
												loading="lazy"
												decoding="async"
											/>
										) : (
											<div
												class="flex h-full w-full items-center justify-center bg-gradient-to-br from-nq-border/90 to-nq-accent/10"
												aria-hidden="true"
											>
												<span class="font-sans text-[10px] tracking-widest text-nq-muted">NO IMAGE</span>
											</div>
										)}
									</div>
									<div class="flex min-w-0 flex-1 flex-col gap-2">
										<h3 class="font-serif text-base font-semibold leading-snug text-nq-ink sm:text-lg">
											<span class="transition-colors group-hover:text-nq-accent-warm">{post.data.title ?? '無題'}</span>
										</h3>
										{post.data.description ? (
											<p class="line-clamp-2 font-sans text-sm leading-relaxed text-nq-ink/78">
												{post.data.description}
											</p>
										) : null}
										<p class:list={[catLabelClass, 'mt-auto w-fit sm:mt-0']}>{categoryLabel(post)}</p>
										<p class="font-sans text-xs tabular-nums text-nq-muted">{formatDate(post)}</p>
									</div>
								</a>
							</li>
						))}
					</ul>
				) : (
					<p class="font-sans text-sm text-nq-muted">ピックアップ記事が設定されていません。</p>
				)
			}
		</section>

		<!-- 3. カテゴリ別（最新3件） -->
		<div class="flex flex-col gap-8">
			{CATEGORY_ORDER.map((cat) => {
				const catPosts = latestInCategory(cat, 3);
				return (
					<section class="border-t border-nq-border pt-6 first:border-t-0 first:pt-0">
						<div class="mb-4 flex flex-wrap items-end justify-between gap-2">
							<h2 class="font-serif text-lg font-semibold tracking-tight text-nq-ink sm:text-xl">{cat}</h2>
							<a
								href={`/category/${encodeURIComponent(cat)}`}
								class="font-sans text-[11px] font-semibold tracking-[0.1em] text-nq-muted transition-colors hover:text-nq-accent"
							>
								一覧へ →
							</a>
						</div>
						{catPosts.length ? (
							<ul class="grid grid-cols-1 gap-3 sm:grid-cols-3">
								{catPosts.map((post) => (
									<li>
										<a
											href={`/journal/${post.slug}`}
											class="group flex h-full flex-col overflow-hidden rounded-sm border border-nq-border/80 bg-white/40 transition-colors hover:border-nq-accent/50"
										>
											<div class="relative aspect-[16/10] w-full overflow-hidden bg-nq-border/20">
												{post.data.heroImage ? (
													<img
														src={post.data.heroImage}
														alt=""
														class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
														loading="lazy"
														decoding="async"
													/>
												) : (
													<div
														class="flex h-full w-full items-center justify-center bg-gradient-to-br from-nq-border/90 to-nq-accent/10"
														aria-hidden="true"
													>
														<span class="font-sans text-[10px] tracking-widest text-nq-muted">NO IMAGE</span>
													</div>
												)}
											</div>
											<div class="flex flex-1 flex-col gap-2 p-2.5">
												<p class:list={[catLabelClass]}>{categoryLabel(post)}</p>
												<h3 class="line-clamp-2 font-serif text-sm font-semibold leading-snug text-nq-ink">
													{post.data.title ?? '無題'}
												</h3>
												<p class="mt-auto font-sans text-xs tabular-nums text-nq-muted">{formatDate(post)}</p>
											</div>
										</a>
									</li>
								))}
							</ul>
						) : (
							<p class="font-sans text-sm text-nq-muted">このカテゴリの記事はまだありません。</p>
						)}
					</section>
				);
			})}
		</div>

		<!-- 4. アロマチャットバナー -->
		<section class="mt-10 border-t border-nq-border pt-8" aria-label="精油辞典 アロマニカ">
			<div
				class="flex flex-col items-start justify-between gap-5 rounded-sm bg-nq-accent px-5 py-7 text-white sm:flex-row sm:items-center sm:px-8"
			>
				<div class="space-y-2">
					<p class="font-serif text-lg font-semibold tracking-tight text-white sm:text-xl">精油辞典　アロマニカ</p>
					<p class="max-w-xl font-sans text-sm leading-relaxed text-white/92">
						AIチャットで選ぶエッセンシャルオイル
					</p>
				</div>
				<a
					href="/aroma-chat"
					class="inline-flex shrink-0 items-center justify-center border border-white/45 bg-white/12 px-6 py-3 font-sans text-xs font-bold tracking-[0.12em] text-white transition-colors hover:bg-white/22"
				>
					チャットを開く
				</a>
			</div>
		</section>
	</div>
</Layout>
