---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('journal');
const sortedPosts = posts.sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return dateB - dateA;
});
---

<Layout title="ジャーナル | Natural Quest" description="Natural Quest の記事一覧です。">
	<header class="mb-10 border-b border-nq-border pb-8">
		<h1 class="font-serif text-3xl font-semibold tracking-tight sm:text-4xl">ジャーナル</h1>
		<p class="mt-3 max-w-2xl font-sans text-sm text-nq-muted">
			ライフと住むを中心に、ナチュラルな暮らしの記事を掲載しています。
		</p>
	</header>
	<ul class="space-y-8">
		{sortedPosts.map((post) => (
			<li class="border-b border-nq-border pb-8 last:border-0">
				<p class="font-sans text-sm text-nq-muted">
					{post.data.pubDate
						? post.data.pubDate.toLocaleDateString('ja-JP', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})
						: '日付未設定'}
				</p>
				<h2 class="mt-2 font-serif text-xl font-semibold sm:text-2xl">
					<a
						href={`/journal/${post.slug}`}
						class="text-nq-text underline decoration-nq-border decoration-1 underline-offset-[6px] transition-colors hover:text-nq-accent hover:decoration-nq-accent"
					>
						{post.data.title ?? '無題の記事'}
					</a>
				</h2>
			</li>
		))}
	</ul>
</Layout>
