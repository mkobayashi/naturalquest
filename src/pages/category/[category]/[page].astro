---
import Layout from '../../../layouts/Layout.astro';
import JournalForbesList from '../../../components/JournalForbesList.astro';
import JournalPagination from '../../../components/JournalPagination.astro';
import { getCollection } from 'astro:content';
import {
	getSortedPostsInCategory,
	totalPagesFor,
	LIST_PAGE_SIZE,
} from '../../../lib/journalListing';

export async function getStaticPaths() {
	const posts = await getCollection('journal');
	const names = new Set<string>();
	for (const p of posts) {
		for (const c of p.data.categories ?? []) {
			if (c) names.add(c);
		}
	}
	const paths: { params: { category: string; page: string } }[] = [];
	for (const category of names) {
		const sorted = await getSortedPostsInCategory(category);
		const tp = totalPagesFor(sorted.length);
		for (let p = 1; p <= tp; p++) {
			paths.push({ params: { category, page: String(p) } });
		}
	}
	return paths;
}

const categoryParam = Astro.params.category;
const pageParam = Astro.params.page;
if (categoryParam === undefined || pageParam === undefined) {
	return Astro.redirect('/journal');
}

const pageNum = parseInt(pageParam, 10);
if (pageNum === 1) {
	return Astro.redirect(`/category/${encodeURIComponent(categoryParam)}`);
}
if (Number.isNaN(pageNum) || pageNum < 2) {
	return Astro.redirect('/journal');
}

const category = categoryParam;

const sorted = await getSortedPostsInCategory(category);
const totalPageCount = totalPagesFor(sorted.length);

if (pageNum > totalPageCount) {
	return Astro.redirect(`/category/${encodeURIComponent(category)}`);
}

const pagePosts = sorted.slice((pageNum - 1) * LIST_PAGE_SIZE, pageNum * LIST_PAGE_SIZE);

const pageTitle = `カテゴリ「${category}」（${pageNum}/${totalPageCount}ページ）| Natural Quest`;
const pageDescription = `「${category}」の記事一覧 ${pageNum}/${totalPageCount}ページ — Natural Quest ジャーナル`;

const listBasePath = `/category/${encodeURIComponent(category)}`;
---

<Layout title={pageTitle} description={pageDescription}>
	<nav class="mb-5 font-sans text-xs tracking-wide text-nq-muted sm:text-sm" aria-label="パンくず">
		<a href="/" class="transition-colors hover:text-nq-accent">トップ</a>
		<span class="mx-1.5 text-nq-border" aria-hidden="true">›</span>
		<a href="/journal" class="transition-colors hover:text-nq-accent">ジャーナル</a>
		<span class="mx-1.5 text-nq-border" aria-hidden="true">›</span>
		<a href={listBasePath} class="transition-colors hover:text-nq-accent">{category}</a>
		<span class="mx-1.5 text-nq-border" aria-hidden="true">›</span>
		<span class="text-nq-ink">{pageNum}ページ目</span>
	</nav>

	<header class="mb-6 border-b border-nq-border pb-5 sm:mb-8 sm:pb-6">
		<h1 class="font-serif text-2xl font-semibold tracking-tight text-nq-ink sm:text-3xl">{category}</h1>
		<p class="mt-2 font-sans text-xs text-nq-muted sm:text-sm">
			{sorted.length} 件中 {(pageNum - 1) * LIST_PAGE_SIZE + 1}〜{Math.min(pageNum * LIST_PAGE_SIZE, sorted.length)} 件を表示（{pageNum} / {totalPageCount} ページ）
		</p>
	</header>

	<JournalForbesList posts={pagePosts} pageLabel={category} mode="category" />
	<JournalPagination currentPage={pageNum} totalPages={totalPageCount} basePath={listBasePath} />
</Layout>
