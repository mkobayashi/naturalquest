---
import Layout from '../../layouts/Layout.astro';
import JournalForbesList from '../../components/JournalForbesList.astro';
import JournalPagination from '../../components/JournalPagination.astro';
import { getCollection } from 'astro:content';
import {
	getSortedPostsWithTag,
	totalPagesFor,
	LIST_PAGE_SIZE,
} from '../../lib/journalListing';

export async function getStaticPaths() {
	const posts = await getCollection('journal');
	const names = new Set<string>();
	for (const p of posts) {
		for (const t of p.data.tags ?? []) {
			if (t) names.add(t);
		}
	}
	return Array.from(names).map((tag) => ({ params: { tag } }));
}

const tagParam = Astro.params.tag;
if (tagParam === undefined) {
	return Astro.redirect('/journal');
}

const tag = tagParam;

const sorted = await getSortedPostsWithTag(tag);
const totalPageCount = totalPagesFor(sorted.length);
const pagePosts = sorted.slice(0, LIST_PAGE_SIZE);

const pageTitle = `タグ「${tag}」| Natural Quest`;
const pageDescription = `「${tag}」の記事一覧（${sorted.length}件）— Natural Quest ジャーナル`;

const listBasePath = `/tag/${encodeURIComponent(tag)}`;
---

<Layout title={pageTitle} description={pageDescription}>
	<nav class="mb-5 font-sans text-xs tracking-wide text-nq-muted sm:text-sm" aria-label="パンくず">
		<a href="/" class="transition-colors hover:text-nq-accent">トップ</a>
		<span class="mx-1.5 text-nq-border" aria-hidden="true">›</span>
		<a href="/journal" class="transition-colors hover:text-nq-accent">ジャーナル</a>
		<span class="mx-1.5 text-nq-border" aria-hidden="true">›</span>
		<span class="text-nq-ink">#{tag}</span>
	</nav>

	<header class="mb-6 border-b border-nq-border pb-5 sm:mb-8 sm:pb-6">
		<h1 class="font-serif text-2xl font-semibold tracking-tight text-nq-ink sm:text-3xl">#{tag}</h1>
		<p class="mt-2 font-sans text-xs text-nq-muted sm:text-sm">{sorted.length} 件</p>
	</header>

	{
		sorted.length ? (
			<>
				<JournalForbesList posts={pagePosts} mode="tag" />
				<JournalPagination
					currentPage={1}
					totalPages={totalPageCount}
					basePath={listBasePath}
				/>
			</>
		) : (
			<p class="font-sans text-sm text-nq-muted">このタグの記事はまだありません。</p>
		)
	}
</Layout>
