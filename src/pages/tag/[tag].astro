---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('journal');
	const names = new Set<string>();
	for (const p of posts) {
		for (const t of p.data.tags ?? []) {
			if (t) names.add(t);
		}
	}
	return Array.from(names).map((tag) => ({ params: { tag } }));
}

const tagParam = Astro.params.tag;
if (tagParam === undefined) {
	return Astro.redirect('/journal');
}

const tag = tagParam;

const allPosts = await getCollection('journal');
const matching = allPosts.filter((p) => (p.data.tags ?? []).includes(tag));
const sorted = matching.sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
	return dateB - dateA;
});

const pageTitle = `タグ「${tag}」| Natural Quest`;
const pageDescription = `「${tag}」の記事一覧（${sorted.length}件）— Natural Quest ジャーナル`;
---

<Layout title={pageTitle} description={pageDescription}>
	<nav class="mb-8 font-sans text-sm text-nq-muted" aria-label="パンくず">
		<a href="/" class="underline decoration-nq-border underline-offset-2 hover:text-nq-accent">トップ</a>
		<span class="mx-2" aria-hidden="true">/</span>
		<a href="/journal" class="underline decoration-nq-border underline-offset-2 hover:text-nq-accent">ジャーナル</a>
		<span class="mx-2" aria-hidden="true">/</span>
		<span class="text-nq-text">#{tag}</span>
	</nav>

	<header class="mb-10 border-b border-nq-border pb-8">
		<h1 class="font-serif text-3xl font-semibold tracking-tight sm:text-4xl">タグ：{tag}</h1>
		<p class="mt-3 font-sans text-sm text-nq-muted">{sorted.length} 件の記事</p>
	</header>

	<ul class="space-y-8">
		{sorted.map((post) => (
			<li class="border-b border-nq-border pb-8 last:border-0">
				<p class="font-sans text-sm text-nq-muted">
					{post.data.pubDate
						? post.data.pubDate.toLocaleDateString('ja-JP', {
								year: 'numeric',
								month: 'long',
								day: 'numeric',
							})
						: '日付未設定'}
				</p>
				<h2 class="mt-2 font-serif text-xl font-semibold sm:text-2xl">
					<a
						href={`/journal/${post.slug}`}
						class="text-nq-text underline decoration-nq-border decoration-1 underline-offset-[6px] transition-colors hover:text-nq-accent hover:decoration-nq-accent"
					>
						{post.data.title ?? '無題の記事'}
					</a>
				</h2>
				{post.data.categories?.length ? (
					<p class="mt-2 flex flex-wrap gap-x-2 gap-y-1 font-sans text-xs text-nq-muted">
						{post.data.categories.slice(0, 5).map((cat) => (
							<a
								href={`/category/${encodeURIComponent(cat)}`}
								class="text-nq-accent underline decoration-nq-border underline-offset-2 hover:decoration-nq-accent"
							>
								{cat}
							</a>
						))}
					</p>
				) : null}
			</li>
		))}
	</ul>
</Layout>
