---
import type { CollectionEntry } from 'astro:content';

interface Props {
	posts: CollectionEntry<'journal'>[];
	mode: 'category' | 'tag';
	currentTags?: string[];
}

const { posts, mode, currentTags } = Astro.props;
const currentTagSet = new Set(currentTags ?? []);

function formatDateForbes(d: Date | undefined): string {
	if (!d) return '—';
	const dt = new Date(d);
	return `${dt.getFullYear()}.${dt.getMonth() + 1}.${dt.getDate()}`;
}
---

<ul class="flex flex-col divide-y divide-nq-border/70">
	{
		posts.map((post) => (
			<li class="py-6 first:pt-0 last:pb-0 sm:py-7">
				<article class="flex flex-row gap-3 sm:gap-5">
					<a
						href={`/journal/${post.slug}`}
						class="relative aspect-video w-[min(38%,11rem)] shrink-0 overflow-hidden bg-nq-border/35 ring-1 ring-nq-border/40 transition-opacity hover:opacity-95 sm:w-[min(34%,13rem)]"
					>
						{post.data.heroImage ? (
							<img
								src={post.data.heroImage}
								alt={post.data.title ?? ''}
								class="absolute inset-0 h-full w-full object-cover object-center"
								loading="lazy"
								decoding="async"
							/>
						) : (
							<div class="thumb-fallback" aria-hidden="true">
								<img src="/logo.svg" alt="Natural Quest" />
							</div>
						)}
					</a>
					<div class="flex min-w-0 flex-1 flex-col justify-center gap-2">
						{post.data.tags?.length ? (
							<div class="mb-2 flex flex-wrap gap-1">
								{post.data.tags.map((t) => {
									const isCommon = currentTagSet.has(t);
									return (
										<span
											class:list={[
												'font-sans text-[9px] tracking-wide px-1.5 py-0.5 rounded-sm border',
												isCommon
													? 'border-nq-accent text-nq-accent bg-nq-accent/20'
													: 'border-nq-border text-nq-muted',
											]}
										>
											{t}
										</span>
									);
								})}
							</div>
						) : null}

						<h2 class="font-serif text-[1.05rem] font-semibold leading-snug tracking-tight text-nq-ink sm:text-lg">
							<a href={`/journal/${post.slug}`} class="transition-colors hover:text-nq-accent">
								{post.data.title ?? '無題の記事'}
							</a>
						</h2>

						<time
							class="font-sans text-[11px] tabular-nums text-nq-muted sm:text-xs"
							datetime={post.data.pubDate ? post.data.pubDate.toISOString() : undefined}
						>
							{formatDateForbes(post.data.pubDate)}
						</time>
						{post.data.description ? (
							<p class="line-clamp-2 font-sans text-[13px] leading-relaxed text-nq-ink/72 sm:text-sm">
								{post.data.description}
							</p>
						) : null}
					</div>
				</article>
			</li>
		))
	}
</ul>

<style>
	.thumb-fallback {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		background: #f5f2eb;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.thumb-fallback img {
		width: 48%;
		max-width: 120px;
		opacity: 0.45;
	}
</style>
