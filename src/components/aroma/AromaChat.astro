---
import OilCardTemplate from './OilCard.astro';

type Oil = {
	id: string;
	name: string;
	latin?: string;
	note?: string;
	scent_type?: string;
	catch?: string;
	effects?: string[];
	indications?: string[];
	lead?: string;
	for_mind?: string;
	for_body?: string;
	for_purpose?: string;
	for_beauty?: string;
	for_purpose_other?: string;
	for_other?: string;
	caution?: string;
	usage?: string[];
};

const { oilsData } = Astro.props as {
	oilsData: Oil[];
};

const workerUrl = import.meta.env.PUBLIC_AROMA_WORKER_URL ?? '';
---

<div class="nq-aroma-chat" id="aroma-chat">
	<div class="nq-chat-toolbar">
		<button type="button" id="nq-reset-btn" class="nq-reset-btn">最初からやり直す</button>
	</div>
	<div class="nq-chat-messages-shell">
		<div class="nq-chat-messages" id="nq-chat-messages">
			<div class="nq-bubble nq-ai">
				<div class="nq-bubble-text">
					こんにちは。求める精油のイメージを、目的や気分、症状などでAIに問いかけてください。知りたい精油がすでにある場合は、精油名を入力してください。
				</div>
			</div>
		</div>
	</div>

	<div class="nq-chat-input">
		<textarea
			id="nq-chat-input"
			placeholder="例：最近眠れなくて、頭もぼーっとしています"
			rows="2"
		></textarea>
		<button id="nq-send-btn" class="nq-send-btn" type="button">送る</button>
	</div>
	<p class="nq-chat-note">※妊娠中・授乳中・持病のある方は専門家にご相談ください</p>

	<OilCardTemplate />
</div>

<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>

<script define:vars={{ oilsData, workerUrl }}>
	const WORKER_URL = workerUrl;

	const messagesEl = document.getElementById('nq-chat-messages');
	const resetBtn = document.getElementById('nq-reset-btn');
	const inputEl = document.getElementById('nq-chat-input');
	const sendBtn = document.getElementById('nq-send-btn');
	const tpl = document.getElementById('nq-oil-card-template');

	if (!messagesEl || !resetBtn || !inputEl || !sendBtn || !tpl) {
		throw new Error('AromaChat: required elements not found');
	}

	const INITIAL_CHAT_MESSAGES_HTML = `<div class="nq-bubble nq-ai">
			<div class="nq-bubble-text">
				こんにちは。求める精油のイメージを、目的や気分、症状などでAIに問いかけてください。知りたい精油がすでにある場合は、精油名を入力してください。
			</div>
		</div>`;

	/** @type {{role:'user'|'assistant', content:string}[]} */
	let history = [];

	function escapeHtml(s) {
		return String(s)
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;')
			.replaceAll("'", '&#39;');
	}

	/** 「- 」で始まる行が3行以上連続する最初のブロックを抜き出し、選択肢として返す */
	function extractChoiceList(displayText) {
		const lines = displayText.split('\n');
		const isBulletLine = (line) => /^\s*-\s+/.test(line);

		let i = 0;
		while (i < lines.length) {
			if (!isBulletLine(lines[i])) {
				i++;
				continue;
			}
			const start = i;
			while (i < lines.length && isBulletLine(lines[i])) i++;
			const len = i - start;
			if (len >= 3) {
				const choices = lines.slice(start, i).map((line) => line.replace(/^\s*-\s+/, '').trim());
				const content = [...lines.slice(0, start), ...lines.slice(i)].join('\n').replace(/\n{3,}/g, '\n\n').trim();
				return { content, choices };
			}
		}
		return { content: displayText, choices: [] };
	}

	function renderAiHtml(text) {
		return typeof marked !== 'undefined' && marked.parse ? marked.parse(text) : escapeHtml(text).replaceAll('\n', '<br>');
	}

	const SUGGESTION_HEADING_HTML =
		'<p class="suggestion-label">〔 あなたにおすすめの精油 〕</p>';

	/**
	 * @param {'user'|'ai'} role
	 * @param {string} text
	 * @param {{ choices?: string[], suggestionHeading?: boolean }} [options]
	 */
	function appendBubble(role, text, options = {}) {
		const id = 'nq-bubble-' + Date.now() + '-' + Math.random().toString(16).slice(2);
		const choices = options.choices ?? [];
		const suggestionPrefix = options.suggestionHeading ? SUGGESTION_HEADING_HTML : '';

		/** messagesEl 直下の追加ブロック（スクロール位置の基準） */
		let bubble;

		if (role === 'ai' && choices.length > 0) {
			const block = document.createElement('div');
			block.className = 'nq-ai-block';
			block.id = id;

			const aiBubble = document.createElement('div');
			aiBubble.className = 'nq-bubble nq-ai';
			const inner = document.createElement('div');
			inner.className = 'nq-bubble-text';
			inner.innerHTML = suggestionPrefix + renderAiHtml(text || '');
			aiBubble.appendChild(inner);
			block.appendChild(aiBubble);

			const row = document.createElement('div');
			row.className = 'nq-choice-row';
			for (const label of choices) {
				const btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'nq-choice-btn';
				btn.textContent = label;
				btn.addEventListener('click', () => {
					if (sendBtn.disabled) return;
					sendMessage(label);
				});
				row.appendChild(btn);
			}
			block.appendChild(row);
			messagesEl.appendChild(block);
			bubble = block;
		} else {
			const div = document.createElement('div');
			div.className = 'nq-bubble ' + (role === 'user' ? 'nq-user' : 'nq-ai');
			div.id = id;
			const inner = document.createElement('div');
			inner.className = 'nq-bubble-text';
			if (role === 'user') {
				inner.innerHTML = escapeHtml(text).replaceAll('\n', '<br>');
			} else {
				inner.innerHTML = suggestionPrefix + renderAiHtml(text);
			}
			div.appendChild(inner);
			messagesEl.appendChild(div);
			bubble = div;
		}
		const bubbleTop = bubble.offsetTop - messagesEl.offsetTop;
		messagesEl.scrollTop = bubbleTop;
		return id;
	}

	function parseSuggestedIds(replyText) {
		const raw = String(replyText ?? '');
		let ids = [];

		const parseSuggestionIds = (jsonStr) => {
			try {
				const parsed = JSON.parse(jsonStr.trim());
				if (!Array.isArray(parsed?.suggestions)) return [];
				return parsed.suggestions.map((s) => String(s?.id ?? '').trim()).filter(Boolean);
			} catch {
				return [];
			}
		};

		// ```json / ```JSON / 言語なしフェンスのいずれにも対応
		const fenced = raw.match(/```(?:json)?\s*([\s\S]*?)```/i);
		if (fenced) {
			ids = parseSuggestionIds(fenced[1]);
		}

		// フェンスが欠ける・形式がずれた場合のフォールバック
		if (!ids.length) {
			const loose = raw.match(/\{\s*"suggestions"\s*:\s*\[[\s\S]*?\]\s*\}/);
			if (loose) ids = parseSuggestionIds(loose[0]);
		}

		const displayText = raw.replace(/```(?:json)?\s*[\s\S]*?```/gi, '').trim();
		return { displayText, ids };
	}

	function findOilBySuggestionId(rawId) {
		const id = String(rawId ?? '').trim();
		if (!id) return undefined;
		const lower = id.toLowerCase();
		return oilsData.find((o) => o.id === id || (o.id && String(o.id).toLowerCase() === lower));
	}

	function makeTag(text, variant) {
		const span = document.createElement('span');
		span.className = 'nq-tag' + (variant ? ' ' + variant : '');
		span.textContent = text;
		return span;
	}

	function setText(el, text) {
		el.textContent = text ?? '';
	}

	/** oil.usage の各ラベルに対応するアイコン */
	const usageIconMap = {
		芳香浴: '/images/usage/usage_aroma.png',
		アロマバス: '/images/usage/usage_bath.png',
		オイルマッサージ: '/images/usage/usage_oil.png',
		足浴: '/images/usage/usage_point.png',
		サシェ: '/images/usage/usage_other.png',
		軟膏: '/images/usage/usage_other.png',
		ヘアシャンプー: '/images/usage/usage_other.png',
		'クリーニング（希釈液）': '/images/usage/usage_other.png',
	};

	const USAGE_ICON_FALLBACK = '/images/usage/usage_other.png';

	/**
	 * @param {string[]} ids
	 * @param {string} anchorAfterId appendBubble が返した AI ブロックの id（吹き出し直後にカードを差し込む）
	 */
	function renderOilCards(ids, anchorAfterId) {
		const anchor = document.getElementById(anchorAfterId);
		if (!anchor) return;

		const wrapper = document.createElement('div');
		wrapper.className = 'nq-oil-results';

		ids.forEach((id) => {
			const oil = findOilBySuggestionId(id);
			if (!oil) return;

			const fragment = tpl.content.cloneNode(true);
			const card = fragment.querySelector('.nq-oil-card');
			if (!card) return;

			const img = fragment.querySelector('[data-field="image"]');
			if (img) {
				img.src = `/images/oils/full_${oil.id}.png`;
				img.alt = oil.name || '';
				img.onerror = () => {
					img.removeAttribute('src');
					img.alt = '';
				};
			}

			const meta = fragment.querySelector('[data-field="meta"]');
			if (meta) {
				const notePart = oil.note ? `${oil.note}ノート　` : '';
				setText(meta, `${notePart}${oil.scent_type ?? ''}`.trim());
			}

			const name = fragment.querySelector('[data-field="name"]');
			if (name) setText(name, oil.name ?? '');

			const latin = fragment.querySelector('[data-field="latin"]');
			if (latin) setText(latin, oil.latin ?? '');

			const catchEl = fragment.querySelector('[data-field="catch"]');
			if (catchEl) {
				const v = oil.catch ?? '';
				catchEl.hidden = !v;
				setText(catchEl, v);
			}

			const effects = fragment.querySelector('[data-field="effects"]');
			if (effects) {
				(oil.effects ?? []).slice(0, 4).forEach((e) => effects.appendChild(makeTag(e)));
			}

			const indications = fragment.querySelector('[data-field="indications"]');
			if (indications) {
				(oil.indications ?? []).slice(0, 4).forEach((i) => indications.appendChild(makeTag(i, 'nq-tag-ind')));
			}

			const lead = fragment.querySelector('[data-field="lead"]');
			if (lead) {
				const v = oil.lead ?? '';
				lead.hidden = !v;
				if (v) {
					lead.innerHTML = escapeHtml(v).replace(/\n/g, '<br><br>');
				} else {
					lead.innerHTML = '';
				}
			}

			const secMind = fragment.querySelector('[data-field="section-mind"]');
			const mindText = fragment.querySelector('[data-field="for_mind"]');
			if (secMind && mindText) {
				const v = oil.for_mind ?? '';
				secMind.hidden = !v;
				setText(mindText, v);
			}

			const secBody = fragment.querySelector('[data-field="section-body"]');
			const bodyText = fragment.querySelector('[data-field="for_body"]');
			if (secBody && bodyText) {
				const v = oil.for_body ?? '';
				secBody.hidden = !v;
				setText(bodyText, v);
			}

			const secBeauty = fragment.querySelector('[data-field="section-beauty"]');
			const beautyText = fragment.querySelector('[data-field="for_beauty"]');
			if (secBeauty && beautyText) {
				const v = (oil.for_beauty ?? '').trim();
				secBeauty.hidden = !v;
				setText(beautyText, v);
			}

			const secPurposeOther = fragment.querySelector('[data-field="section-purpose-other"]');
			const purposeOtherText = fragment.querySelector('[data-field="for_purpose_other"]');
			if (secPurposeOther && purposeOtherText) {
				const v = String(oil.for_purpose_other ?? oil.for_other ?? '').trim();
				secPurposeOther.hidden = !v;
				setText(purposeOtherText, v);
			}

			const secCaution = fragment.querySelector('[data-field="section-caution"]');
			const cautionTextEl = fragment.querySelector('[data-field="caution"]');
			if (secCaution && cautionTextEl) {
				const v = (oil.caution ?? '').trim();
				secCaution.hidden = !v;
				setText(cautionTextEl, v);
			}

			const secPurpose = fragment.querySelector('[data-field="section-purpose"]');
			const usageIconsEl = fragment.querySelector('[data-field="usage-icons"]');
			if (secPurpose && usageIconsEl) {
				const usageList = Array.isArray(oil.usage) ? oil.usage : [];
				const showUsageSection = usageList.length > 0;

				secPurpose.hidden = !showUsageSection;
				usageIconsEl.innerHTML = '';
				if (showUsageSection) {
					for (const label of usageList) {
						const item = document.createElement('div');
						item.className = 'oil-usage-item';
						const ic = document.createElement('img');
						ic.src = usageIconMap[label] ?? USAGE_ICON_FALLBACK;
						ic.width = 44;
						ic.height = 44;
						ic.alt = label;
						ic.loading = 'lazy';
						ic.decoding = 'async';
						const cap = document.createElement('span');
						cap.textContent = label;
						item.appendChild(ic);
						item.appendChild(cap);
						usageIconsEl.appendChild(item);
					}
				}
			}

			wrapper.appendChild(fragment);
		});

		if (!wrapper.childNodes.length) return;

		anchor.insertAdjacentElement('afterend', wrapper);
	}

	async function sendMessage(prefill) {
		const text = typeof prefill === 'string' ? prefill.trim() : inputEl.value.trim();
		if (!text) return;

		inputEl.value = '';
		sendBtn.disabled = true;

		appendBubble('user', text);
		history.push({ role: 'user', content: text });

		const loadingId = appendBubble('ai', '考えています...');

		if (!WORKER_URL) {
			document.getElementById(loadingId)?.remove();
			appendBubble('ai', '現在、接続先（Workers URL）が未設定です。環境変数 PUBLIC_AROMA_WORKER_URL を設定してください。');
			sendBtn.disabled = false;
			return;
		}

		try {
			const res = await fetch(WORKER_URL, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ messages: history, oilsData }),
			});

			const data = await res.json();
			const reply = data?.content?.[0]?.text ?? '';

			document.getElementById(loadingId)?.remove();

			const { displayText, ids } = parseSuggestedIds(reply);
			const { content: bodyText, choices } = extractChoiceList(displayText);
			const fallback = '（回答を取得できませんでした）';
			const toShow = bodyText || (choices.length ? '' : fallback);
			const suggestionHeading = ids.length > 0;

			let aiBlockId;
			if (choices.length > 0) {
				aiBlockId = appendBubble('ai', toShow, { choices, suggestionHeading });
			} else {
				aiBlockId = appendBubble('ai', displayText || fallback, { suggestionHeading });
			}

			history.push({ role: 'assistant', content: reply || displayText });

			if (ids.length > 0) renderOilCards(ids, aiBlockId);
		} catch {
			document.getElementById(loadingId)?.remove();
			appendBubble('ai', '申し訳ありません、エラーが発生しました。もう一度お試しください。');
		}

		sendBtn.disabled = false;
		inputEl.focus();
	}

	resetBtn.addEventListener('click', () => {
		history = [];
		messagesEl.innerHTML = INITIAL_CHAT_MESSAGES_HTML;
		inputEl.value = '';
		sendBtn.disabled = false;
		inputEl.focus();
	});

	sendBtn.addEventListener('click', () => sendMessage());

	let isComposing = false;
	let compositionJustEnded = false;

	inputEl.addEventListener('compositionstart', () => {
		isComposing = true;
		compositionJustEnded = false;
	});

	inputEl.addEventListener('compositionend', () => {
		isComposing = false;
		compositionJustEnded = true;
		setTimeout(() => {
			compositionJustEnded = false;
		}, 50);
	});

	inputEl.addEventListener('keydown', (e) => {
		if (e.key === 'Enter' && !e.shiftKey) {
			if (isComposing || compositionJustEnded) {
				e.preventDefault();
				return;
			}
			e.preventDefault();
			sendMessage();
		}
	});
</script>

<!-- JS で追加する吹き出しに data-astro-* が付かないため、チャット周りは is:global + ルートで囲む -->
<style is:global>
	.nq-aroma-chat {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.nq-aroma-chat .nq-chat-toolbar {
		display: flex;
		justify-content: flex-end;
		margin-bottom: 6px;
	}

	.nq-aroma-chat .nq-chat-messages-shell {
		width: 100%;
	}

	.nq-aroma-chat .nq-reset-btn {
		font-size: 12px;
		color: #888;
		background: transparent;
		border: none;
		cursor: pointer;
		text-decoration: underline;
		padding: 4px 0;
		font-family: inherit;
	}

	.nq-aroma-chat .nq-chat-messages {
		background: rgb(248 247 243 / 1);
		border-radius: 12px;
		padding: 1rem;
		min-height: 220px;
		max-height: 420px;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		border: 1px solid rgb(232 228 218 / 1);
	}

	.nq-aroma-chat .nq-ai-block {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.5rem;
		width: 100%;
	}

	.nq-aroma-chat .nq-choice-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: flex-start;
		width: 100%;
		padding-left: 0;
	}

	.nq-aroma-chat .nq-choice-btn {
		border: 0.5px solid #1d9e75;
		color: #0f6e56;
		background: white;
		border-radius: 20px;
		font-size: 15px;
		padding: 5px 12px;
		line-height: 1.4;
		cursor: pointer;
		font-family: inherit;
	}

	.nq-aroma-chat .nq-choice-btn:hover {
		background: #e1f5ee;
	}

	.nq-aroma-chat .nq-bubble {
		display: flex;
		width: 100%;
	}
	.nq-aroma-chat .nq-bubble.nq-user {
		flex-direction: row-reverse;
	}

	.nq-aroma-chat .nq-bubble-text {
		padding: 10px 14px;
		max-width: 80%;
	}

	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text {
		font-size: 16px;
		line-height: 1.7;
		background: white;
		border: 0.5px solid #e8e4da;
		border-radius: 4px 12px 12px 12px;
		color: rgb(51 51 51 / 1);
	}

	.nq-aroma-chat .suggestion-label {
		font-size: 13px;
		font-weight: 500;
		color: #2d6a4f;
		letter-spacing: 0.08em;
		margin-bottom: 8px;
		border-bottom: 0.5px solid #c8e6c9;
		padding-bottom: 6px;
	}

	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text p {
		margin: 0 0 0.5em;
	}
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text p:last-child {
		margin-bottom: 0;
	}
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text h1,
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text h2,
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text h3 {
		font-size: 1em;
		font-weight: 600;
		margin: 0.75em 0 0.35em;
		line-height: 1.35;
	}
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text h1:first-child,
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text h2:first-child,
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text h3:first-child {
		margin-top: 0;
	}
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text ul,
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text ol {
		margin: 0.35em 0 0.5em;
		padding-left: 1.25em;
	}
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text li {
		margin: 0.15em 0;
	}

	/* 本文内の太字（精油名など）：ゴシックのまま太すぎないようセリフ＋セミボールドで統一 */
	.nq-aroma-chat .nq-bubble.nq-ai .nq-bubble-text strong {
		font-family: var(--font-serif);
		font-weight: 600;
		color: var(--color-nq-ink);
		letter-spacing: 0.02em;
	}

	.nq-aroma-chat .nq-bubble.nq-user .nq-bubble-text {
		font-size: 16px;
		line-height: 1.7;
		background: #e1f5ee;
		color: #085041;
		border-radius: 12px 4px 12px 12px;
	}

	.nq-aroma-chat .nq-chat-messages .nq-oil-results {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 0.75rem;
		max-width: 100%;
		width: 100%;
		box-sizing: border-box;
	}

	.nq-aroma-chat .nq-oil-card {
		flex: 1;
		min-width: 240px;
		max-width: 360px;
		background: white;
		border: 1px solid rgb(232 228 218 / 1);
		border-radius: 12px;
		overflow: hidden;
	}

	.nq-aroma-chat .nq-oil-card-img {
		float: left;
		width: 42%;
		aspect-ratio: 3 / 4;
		margin: 0 0.75rem 0.5rem 0;
		background: transparent;
	}

	.nq-aroma-chat .nq-oil-card-img img {
		width: 100%;
		height: 100%;
		object-fit: contain;
		object-position: top;
		display: block;
	}

	.nq-aroma-chat .nq-oil-card-body {
		padding: 1rem;
	}

