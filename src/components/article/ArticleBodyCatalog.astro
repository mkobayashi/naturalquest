---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'journal'>;
	Content: any;
	components?: Record<string, any>;
}

const { post, Content, components } = Astro.props;
const introText = post.data.description;
const items = post.data.items ?? [];
---

<div class="mt-10 py-2">
	{introText ? (
		<p class="mb-10 font-sans text-sm leading-relaxed text-nq-text sm:text-base">
			{introText}
		</p>
	) : null}

	{items.length ? (
		<div class="border-t border-nq-border">
			{items.map((item, i) => (
				<section class="border-b border-nq-border py-8">
					<div
						class:list={[
							'flex flex-col gap-5 sm:flex-row sm:items-stretch sm:gap-8',
							i % 2 === 1 && 'sm:flex-row-reverse',
						]}
					>
						<div class="w-full sm:w-1/2">
							<div class="aspect-[4/3] overflow-hidden rounded-sm bg-nq-border/25">
								{item.image ? (
									<img
										src={item.image}
										alt=""
										class="h-full w-full object-cover"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div
										class="h-full w-full bg-gradient-to-br from-nq-border/70 via-nq-border/40 to-nq-border/20"
										aria-hidden="true"
									/>
								)}
							</div>
						</div>

						<div class="w-full sm:w-1/2">
							<div class="flex h-full flex-col">
								{(item.tag ?? item.badge) ? (
									<p class="mb-2">
										<span class="inline-flex items-center rounded border border-nq-accent/35 bg-nq-accent/10 px-2 py-1 font-sans text-[11px] font-bold leading-tight tracking-[0.08em] text-nq-accent">
											{item.tag ?? item.badge}
										</span>
									</p>
								) : null}

								<h2 class="font-serif text-lg font-semibold leading-snug text-nq-ink">{item.name}</h2>

								{item.specs?.length ? (
									<dl class="mt-3 grid gap-2 font-sans text-xs leading-relaxed text-nq-text">
										{item.specs.map((s) => (
											<div class="grid grid-cols-[7.5rem_1fr] gap-3">
												<dt class="text-nq-muted">{s.key}</dt>
												<dd class="min-w-0">{s.value}</dd>
											</div>
										))}
									</dl>
								) : null}

								{item.body ? (
									<p class="mt-4 font-sans text-xs leading-relaxed text-nq-muted">
										{item.body}
									</p>
								) : null}
							</div>
						</div>
					</div>
				</section>
			))}
		</div>
	) : (
		<div class="mt-10 max-w-none font-sans leading-[1.85] text-nq-text">
			<Content components={components} />
		</div>
	)}
</div>

