---
import type { CollectionEntry } from 'astro:content';

interface Props {
	post: CollectionEntry<'journal'>;
	Content: any;
	components?: Record<string, any>;
}

const { Content, components } = Astro.props;
---

<div
	class="mt-10 max-w-none font-sans text-nq-text [&_a]:text-nq-accent [&_a]:underline [&_a]:decoration-nq-border [&_a]:underline-offset-2 [&_blockquote]:border-l-2 [&_blockquote]:border-nq-accent [&_blockquote]:bg-nq-accent/5 [&_blockquote]:pl-4 [&_blockquote]:py-2 [&_blockquote]:my-6 [&_blockquote]:font-serif [&_blockquote]:italic [&_blockquote]:text-nq-muted [&_blockquote]:rounded-r-sm [&_h2]:mt-12 [&_h2]:mb-6 [&_h2]:font-serif [&_h2]:text-xl [&_h2]:font-normal [&_h2]:border-b [&_h2]:border-nq-border [&_h2]:pb-3 [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:font-serif [&_h3]:text-base [&_h3]:font-normal [&_h4]:mt-6 [&_h4]:mb-2 [&_h4]:font-sans [&_h4]:text-xs [&_h4]:font-bold [&_h4]:tracking-wide [&_h4]:text-nq-text [&_img]:my-6 [&_img]:max-w-full [&_img]:rounded-md [&_li]:mb-1 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:mb-5 [&_p]:leading-[1.9] [&_p]:text-nq-text [&_strong]:font-semibold [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6"
>
	<Content components={components} />
</div>

