---
interface Props {
	currentPage: number;
	totalPages: number;
	/** 1ページ目のURL（末尾スラッシュなし）。例: `/category/住む` */
	basePath: string;
}

const { currentPage, totalPages, basePath } = Astro.props;

function hrefForPage(p: number): string {
	if (p <= 1) return basePath;
	return `${basePath}/${p}`;
}
---

{
	totalPages > 1 ? (
		<nav
			class="mt-10 flex flex-col items-center gap-4 border-t border-nq-border pt-8 sm:mt-12 sm:gap-5 sm:pt-10"
			aria-label="ページネーション"
		>
			<ul class="flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
				{Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
					<li>
						{p === currentPage ? (
							<span
								class="flex min-w-[2.25rem] items-center justify-center rounded-sm border border-nq-text bg-nq-text px-2.5 py-1.5 font-sans text-xs font-semibold tabular-nums text-nq-bg"
								aria-current="page"
							>
								{p}
							</span>
						) : (
							<a
								href={hrefForPage(p)}
								class="flex min-w-[2.25rem] items-center justify-center rounded-sm border border-nq-border bg-white/50 px-2.5 py-1.5 font-sans text-xs font-medium tabular-nums text-nq-ink transition-colors hover:border-nq-accent hover:text-nq-accent"
							>
								{p}
							</a>
						)}
					</li>
				))}
			</ul>
			<div class="flex items-center gap-6 font-sans text-xs font-medium text-nq-muted sm:text-sm">
				{currentPage > 1 ? (
					<a
						href={hrefForPage(currentPage - 1)}
						class="transition-colors hover:text-nq-accent"
					>
						← 前へ
					</a>
				) : (
					<span class="opacity-40">← 前へ</span>
				)}
				<span class="tabular-nums text-nq-ink/80">
					{currentPage} / {totalPages}
				</span>
				{currentPage < totalPages ? (
					<a
						href={hrefForPage(currentPage + 1)}
						class="transition-colors hover:text-nq-accent"
					>
						次へ →
					</a>
				) : (
					<span class="opacity-40">次へ →</span>
				)}
			</div>
		</nav>
	) : null
}
