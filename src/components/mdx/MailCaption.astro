---
const { caption } = Astro.props;
---

<figure class="mail-figure">
	<slot />
	<figcaption class="mail-caption">{caption}</figcaption>
</figure>

<style>
	.mail-figure {
		margin: 32px 0;
	}
	.mail-figure :global(img) {
		width: 100%;
		border: 1px solid #ddd;
		border-radius: 3px;
		display: block;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
	}
	.mail-caption {
		font-family: 'Noto Sans JP', sans-serif;
		font-size: 12px;
		color: #888;
		margin-top: 8px;
		line-height: 1.6;
	}
</style>
