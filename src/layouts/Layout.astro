---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	/** 記事本文など max-width 720px */
	narrow?: boolean;
	/** 検索エンジンにインデックスさせない（非公開記事など） */
	noindex?: boolean;
}

const {
	title = 'Natural Quest',
	description,
	narrow = false,
	noindex = false,
} = Astro.props;

const navItems = [
	{ label: '食', href: '/category/食' },
	{ label: '健康', href: '/category/健康' },
	{ label: '住む', href: '/category/住む' },
	{ label: 'NOTE', href: '/category/NOTE' },
	{ label: '精油を探す', href: '/aroma/' },
] as const;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description ? <meta name="description" content={description} /> : null}
		{noindex ? <meta name="robots" content="noindex, nofollow" /> : null}
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&family=Noto+Serif+JP:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&display=swap"
			rel="stylesheet"
		/>
		<link
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0"
			rel="stylesheet"
		/>
		<style is:global>
			.material-symbols-outlined {
				font-size: 1.25rem;
				font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
			}
			#nav-menu-button .nav-icon-line {
				transition:
					transform 0.2s ease,
					opacity 0.2s ease;
				transform-origin: center;
			}
			#nav-menu-button.is-open .nav-icon-top {
				transform: translateY(5px) rotate(45deg);
			}
			#nav-menu-button.is-open .nav-icon-mid {
				opacity: 0;
			}
			#nav-menu-button.is-open .nav-icon-bot {
				transform: translateY(-5px) rotate(-45deg);
			}
		</style>
	</head>
	<body class="flex min-h-screen flex-col text-nq-ink">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[60] focus:rounded focus:bg-nq-accent focus:px-3 focus:py-2 focus:text-white"
		>
			本文へスキップ
		</a>
		<header
			class="sticky top-0 z-50 border-b border-nq-border/80 bg-nq-bg/90 backdrop-blur-xl transition-colors"
		>
			<div
				class="relative mx-auto flex w-full max-w-[1200px] items-center justify-center gap-3 px-3 py-3 sm:justify-between sm:px-5"
			>
				<a
					href="/"
					aria-label="Natural Quest — 自分のナチュラルを見つける"
					class="mx-auto flex min-w-0 flex-col items-center gap-1.5 outline-none focus-visible:ring-2 focus-visible:ring-nq-accent focus-visible:ring-offset-2 focus-visible:ring-offset-nq-bg sm:mx-0 sm:flex-row sm:items-end sm:gap-3"
				>
					<img
						src="/logo.svg"
						alt="Natural Quest"
						class="hidden h-9 w-auto shrink-0 object-contain object-left sm:block"
						loading="eager"
						width="200"
						height="32"
					/>
					<img
						src="/logo-mobile.svg"
						alt="Natural Quest"
						class="block h-8 w-auto shrink-0 object-contain sm:hidden"
						loading="eager"
						width="200"
						height="32"
					/>
					<span class="min-w-0 text-center font-serif text-[0.6rem] leading-none tracking-[0.14em] text-nq-ink/70 sm:translate-y-[-5px] sm:text-left sm:text-[0.7rem] md:text-xs">
						自分のナチュラルを見つける
					</span>
				</a>

				<nav class="hidden items-center gap-8 md:flex" aria-label="主要ナビゲーション">
					{navItems.map((item) => (
						<a
							href={item.href}
							class="font-sans text-[0.9rem] font-bold tracking-[0.06em] text-nq-ink/85 transition-colors hover:text-nq-accent"
						>
							{item.label}
						</a>
					))}
				</nav>

				<div class="absolute right-3 flex items-center gap-2 sm:static sm:right-auto sm:gap-3">
					<a
						href="/journal#site-search"
						class="material-symbols-outlined text-nq-ink/75 transition-colors hover:text-nq-accent"
						aria-label="記事一覧・検索へ"
					>
						search
					</a>
					<button
						type="button"
						id="nav-menu-button"
						class="rounded border border-nq-border bg-white/60 p-1.5 text-nq-ink transition-colors hover:border-nq-accent hover:text-nq-accent focus-visible:outline focus-visible:ring-2 focus-visible:ring-nq-accent md:hidden"
						aria-expanded="false"
						aria-controls="mobile-menu"
						aria-label="メニューを開く"
					>
						<span class="block h-5 w-6" aria-hidden="true">
							<svg
								class="h-full w-full"
								fill="none"
								stroke="currentColor"
								stroke-width="1.75"
								stroke-linecap="round"
								viewBox="0 0 24 24"
							>
								<path class="nav-icon-line nav-icon-top" d="M4 7h16" />
								<path class="nav-icon-line nav-icon-mid" d="M4 12h16" />
								<path class="nav-icon-line nav-icon-bot" d="M4 17h16" />
							</svg>
						</span>
					</button>
				</div>
			</div>
			<div
				id="mobile-menu"
				class="hidden border-t border-nq-border bg-nq-bg md:hidden"
				hidden
			>
				<nav class="mx-auto max-w-[1200px] px-3 py-3 sm:px-5" aria-label="主要ナビゲーション（モバイル）">
					<ul class="flex flex-col gap-0.5 font-sans text-sm">
						{navItems.map((item) => (
							<li>
								<a
									href={item.href}
									class="block rounded-sm px-2 py-2.5 font-bold tracking-wide text-nq-ink transition-colors hover:bg-white/60 hover:text-nq-accent"
								>
									{item.label}
								</a>
							</li>
						))}
					</ul>
				</nav>
			</div>
		</header>
		<script is:inline>
			(function () {
				var btn = document.getElementById('nav-menu-button');
				var panel = document.getElementById('mobile-menu');
				if (!btn || !panel) return;

				function setOpen(open) {
					panel.classList.toggle('hidden', !open);
					panel.hidden = !open;
					btn.setAttribute('aria-expanded', open ? 'true' : 'false');
					btn.setAttribute('aria-label', open ? 'メニューを閉じる' : 'メニューを開く');
					document.body.style.overflow = open ? 'hidden' : '';
					btn.classList.toggle('is-open', open);
				}

				btn.addEventListener('click', function () {
					setOpen(panel.classList.contains('hidden'));
				});

				panel.querySelectorAll('a').forEach(function (a) {
					a.addEventListener('click', function () {
						setOpen(false);
					});
				});

				document.addEventListener('keydown', function (e) {
					if (e.key === 'Escape' && !panel.classList.contains('hidden')) setOpen(false);
				});
			})();
		</script>
		<main id="main" class="flex-1">
			<div
				class:list={[
					'mx-auto w-full px-4 py-6 sm:px-6 sm:py-8 lg:px-10 lg:py-10',
					narrow ? 'max-w-[720px]' : 'max-w-[1200px]',
				]}
			>
				<slot />
			</div>
		</main>
		<footer class="mt-auto border-t border-nq-border/50 bg-nq-text text-nq-bg">
			<div class="mx-auto flex max-w-[1200px] flex-col items-center gap-8 px-4 py-10 sm:px-6">
				<img
					src="/logo.svg"
					alt=""
					class="h-8 w-auto max-w-[220px] object-contain opacity-90 invert"
					width="220"
					height="36"
					loading="lazy"
					decoding="async"
				/>
				<nav
					class="flex flex-wrap items-center justify-center gap-x-2 gap-y-1 font-sans text-xs font-medium tracking-[0.06em] text-nq-bg/75"
					aria-label="フッターリンク"
				>
					<a href="/privacy" class="transition-colors hover:text-nq-bg">プライバシー</a>
					<span class="text-nq-bg/35" aria-hidden="true">|</span>
					<a href="/terms" class="transition-colors hover:text-nq-bg">利用規約</a>
					<span class="text-nq-bg/35" aria-hidden="true">|</span>
					<a href="/about" class="transition-colors hover:text-nq-bg">about</a>
				</nav>
				<p class="w-full text-center font-sans text-[0.65rem] tracking-[0.12em] text-nq-bg/50">
					Copyright © 2026 Natural Quest
				</p>
			</div>
		</footer>
		<button
			type="button"
			id="back-to-top"
			class="fixed bottom-5 right-4 z-40 flex h-10 w-10 items-center justify-center rounded-full border border-white/20 bg-nq-text/85 text-nq-bg shadow-lg backdrop-blur-sm transition-opacity duration-200 hover:bg-nq-accent md:bottom-6 md:right-6"
			aria-label="ページ上部へ戻る"
			hidden
		>
			<span class="material-symbols-outlined !text-xl" aria-hidden="true">arrow_upward</span>
		</button>
		<script is:inline>
			(function () {
				var btn = document.getElementById('back-to-top');
				if (!btn) return;
				function onScroll() {
					var y = window.scrollY || document.documentElement.scrollTop;
					btn.hidden = y < 320;
				}
				window.addEventListener('scroll', onScroll, { passive: true });
				onScroll();
				btn.addEventListener('click', function () {
					window.scrollTo({ top: 0, behavior: 'smooth' });
				});
			})();
		</script>
	</body>
</html>
