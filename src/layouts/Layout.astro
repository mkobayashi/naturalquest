---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	/** 記事本文など max-width 720px */
	narrow?: boolean;
}

const {
	title = 'Natural Quest',
	description,
	narrow = false,
} = Astro.props;

const canonicalBase = 'https://naturalquest.org';
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description ? <meta name="description" content={description} /> : null}
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600&family=DM+Serif+Display&family=Noto+Sans+JP:wght@400;500;600&family=Noto+Serif+JP:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="flex min-h-screen flex-col text-nq-text">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-nq-accent focus:px-3 focus:py-2 focus:text-white"
		>
			本文へスキップ
		</a>
		<header class="border-b border-nq-border bg-nq-bg">
			<div
				class="mx-auto flex max-w-[1200px] flex-col gap-6 px-4 py-8 sm:px-6 lg:flex-row lg:items-end lg:justify-between lg:px-8 lg:py-10"
			>
				<div class="min-w-0">
					<a href="/" class="group block outline-none focus-visible:ring-2 focus-visible:ring-nq-accent focus-visible:ring-offset-2 focus-visible:ring-offset-nq-bg">
						<span class="font-serif text-2xl font-semibold tracking-tight text-nq-text group-hover:text-nq-accent sm:text-[1.75rem]">
							Natural Quest
						</span>
						<span class="mt-1 block font-sans text-sm font-normal tracking-wide text-nq-muted">
							自分のナチュラルを見つける
						</span>
					</a>
				</div>
				<nav aria-label="主要ナビゲーション" class="font-sans text-sm">
					<ul class="flex flex-wrap items-center gap-x-6 gap-y-2 lg:justify-end">
						<li>
							<a
								href="/journal"
								class="text-nq-text underline decoration-nq-border decoration-1 underline-offset-4 transition-colors hover:text-nq-accent hover:decoration-nq-accent"
							>
								ジャーナル
							</a>
						</li>
						<li class="text-nq-muted" aria-hidden="true">|</li>
						<li>
							<a
								href="/category/ライフ"
								class="text-nq-text underline decoration-nq-border decoration-1 underline-offset-4 transition-colors hover:text-nq-accent hover:decoration-nq-accent"
							>
								ライフ
							</a>
						</li>
						<li>
							<a
								href="/category/住む"
								class="text-nq-text underline decoration-nq-border decoration-1 underline-offset-4 transition-colors hover:text-nq-accent hover:decoration-nq-accent"
							>
								住む
							</a>
						</li>
					</ul>
				</nav>
			</div>
		</header>
		<main id="main" class="flex-1">
			<div
				class:list={[
					'mx-auto px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-16',
					narrow ? 'max-w-[720px]' : 'max-w-[1200px]',
				]}
			>
				<slot />
			</div>
		</main>
		<footer class="mt-auto border-t border-nq-border bg-nq-bg">
			<div class="mx-auto max-w-[1200px] px-4 py-12 sm:px-6 lg:px-8">
				<p class="font-sans text-sm leading-relaxed text-nq-muted">
					漆喰・自然素材リフォームのご相談は
					<a
						href="https://bristlecone.jp"
						class="text-nq-accent-warm underline decoration-nq-border decoration-1 underline-offset-4 transition-colors hover:decoration-nq-accent-warm"
						rel="noopener noreferrer"
						target="_blank"
					>
						Bristlecone（ブリストルコーン）
					</a>
					へ。
				</p>
				<p class="mt-6 font-sans text-xs text-nq-muted">
					© {new Date().getFullYear()} Natural Quest ·{' '}
					<a href={canonicalBase} class="underline decoration-nq-border underline-offset-2 hover:text-nq-text">
						naturalquest.org
					</a>
				</p>
			</div>
		</footer>
	</body>
</html>
